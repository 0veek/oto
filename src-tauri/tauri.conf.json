{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Oto",
  "version": "0.1.0",
  "identifier": "dev.oto.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "overlay",
        "title": "Oto",
        "url": "/",
        "width": 340,
        "height": 80,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": false,
        "focus": false,
        "focusable": false
      },
      {
        "label": "settings",
        "title": "Oto Settings",
        "url": "/settings",
        "width": 880,
        "height": 640,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
